-- Blade Ball Auto Parry + Simple UI
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local VirtualInputManager = game:GetService("VirtualInputManager")
local StarterGui = game:GetService("StarterGui")

local Player = Players.LocalPlayer
local Enabled = true
local Killed = false
local LastParry = 0
local Cooldown = 0.15
local SpamEnabled = false
local LastSpam = 0

local function Notify(text)
	pcall(function()
		StarterGui:SetCore("SendNotification", {
			Title = "Auto Parry",
			Text = text,
			Duration = 2
		})
	end)
end

-- UI
local gui = Instance.new("ScreenGui")
gui.Name = "BladeBall AP BY L0RIENTz"
gui.ResetOnSpawn = false
gui.Parent = Player:WaitForChild("PlayerGui")

local frame = Instance.new("Frame", gui)
frame.Size = UDim2.new(0, 220, 0, 185)
frame.Position = UDim2.new(0.5, -110, 0.5, -80)
frame.BackgroundColor3 = Color3.fromRGB(30,30,30)
frame.Active = true
frame.Draggable = true

local title = Instance.new("TextLabel", frame)
title.Size = UDim2.new(1,0,0,30)
title.BackgroundTransparency = 1
title.Text = "BladeBall AP BY L0RIENTz"
title.TextColor3 = Color3.new(1,1,1)

local function makeButton(text, y)
	local b = Instance.new("TextButton", frame)
	b.Size = UDim2.new(0.8,0,0,30)
	b.Position = UDim2.new(0.1,0,0,y)
	b.BackgroundColor3 = Color3.fromRGB(55,55,55)
	b.TextColor3 = Color3.new(1,1,1)
	b.Text = text
	return b
end

local parryBtn = makeButton("Auto Parry(E): ON", 40)
local spamBtn = makeButton("Spam(C): OFF", 80)
local killBtn = makeButton("Kill Script(X)", 120)

local speedLabel = Instance.new("TextLabel", frame)
speedLabel.Size = UDim2.new(0.8,0,0,20)
speedLabel.Position = UDim2.new(0.1,0,0,150)
speedLabel.BackgroundTransparency = 1
speedLabel.TextColor3 = Color3.new(1,1,1)
speedLabel.Text = "Ball Speed: 0"

local function updateButtons()
	parryBtn.Text = "Auto Parry(E): " .. (Enabled and "ON" or "OFF")
	spamBtn.Text = "Spam(C): " .. (SpamEnabled and "ON" or "OFF")
end

parryBtn.MouseButton1Click:Connect(function()
	if Killed then return end
	Enabled = not Enabled
	updateButtons()
end)
spamBtn.MouseButton1Click:Connect(function()
	if Killed then return end
	SpamEnabled = not SpamEnabled
	updateButtons()
end)
local function KillAll()
	Killed = true
	Enabled = false
	SpamEnabled = false
	if gui then gui:Destroy() end
	Notify("Script Killed")
end
killBtn.MouseButton1Click:Connect(KillAll)

UserInputService.InputBegan:Connect(function(input,gp)
	if gp then return end
	if input.KeyCode == Enum.KeyCode.X then
		KillAll()
	elseif input.KeyCode == Enum.KeyCode.E and not Killed then
		Enabled = not Enabled
		updateButtons()
	elseif input.KeyCode == Enum.KeyCode.C and not Killed then
		SpamEnabled = not SpamEnabled
		updateButtons()
	end
end)

local function GetBall()
	local folder = workspace:FindFirstChild("Balls")
	if not folder then return end
	for _, ball in ipairs(folder:GetChildren()) do
		if ball:GetAttribute("realBall") then return ball end
	end
end

local function Parry()
	VirtualInputManager:SendMouseButtonEvent(0,0,0,true,game,0)
	task.wait()
	VirtualInputManager:SendMouseButtonEvent(0,0,0,false,game,0)
	LastParry = tick()
end

RunService.Heartbeat:Connect(function()
	if Killed then return end

	if SpamEnabled then
		local currentBall = GetBall()
		if not currentBall then
			-- keep spam on until ball speed check says otherwise
		else
			local z = currentBall:FindFirstChild("zoomies")
			if z and z.VectorVelocity.Magnitude < 30 then
				SpamEnabled = false
				updateButtons()
				Notify("Spam Click + F: OFF (Ball Speed < 30)")
			else
				local now = tick()
				if now - LastSpam >= math.random(1,5)/10000 then
					VirtualInputManager:SendMouseButtonEvent(0,0,0,true,game,0)
					VirtualInputManager:SendMouseButtonEvent(0,0,0,false,game,0)
					VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.F, false, game)
					VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.F, false, game)
					LastSpam = now
				end
			end
		end
	end

	-- Always update speed label, even if auto parry is OFF
	local uiBall = GetBall()
	if uiBall and uiBall:FindFirstChild("zoomies") then
		speedLabel.Text = "Ball Speed: " .. math.floor(uiBall.zoomies.VectorVelocity.Magnitude)
	else
		speedLabel.Text = "Ball Speed: 0"
	end

	if not Enabled then return end
	local char = Player.Character
	if not char then return end
	local hrp = char:FindFirstChild("HumanoidRootPart")
	if not hrp then return end
	local ball = GetBall()
	if not ball then _G.LastBallDir=nil return end
	if ball:GetAttribute("target") ~= Player.Name then return end
	local zoomies = ball:FindFirstChild("zoomies")
	if not zoomies then return end
	local velocity = zoomies.VectorVelocity
	local speed = velocity.Magnitude
	local distance = (hrp.Position - ball.Position).Magnitude
	if speed < 1 then return end

	local dirToPlayer = (hrp.Position - ball.Position).Unit
	local ballDir = velocity.Unit
	local dot = dirToPlayer:Dot(ballDir)
	_G.LastBallDir = _G.LastBallDir or ballDir
	local dirChange = (_G.LastBallDir - ballDir).Magnitude
	_G.LastBallDir = ballDir
	local timeToHit = distance / speed

	if speed < 60 then
		local slowThreshold = 0.42
		local approaching = dot > 0.35
		local closeRange = distance < 18
		if approaching and (timeToHit <= slowThreshold or closeRange) and tick()-LastParry > Cooldown then
			Parry()
		end
		return
	end

	local strongCurve = dirChange > 0.04
	local lightCurve = dirChange > 0.015

	-- Curve classification functions
	local function IsNoCurve()
		return dirChange <= 0.015
	end
	local function IsLightCurve()
		return dirChange > 0.015 and dirChange <= 0.04
	end
	local function IsStrongCurve()
		return dirChange > 0.04
	end

	local veryFast = speed > 85
	local farAway = distance > 12
	local ultraFast = speed >= 500
	local hyperFast = speed >= 850
	local threshold
	local approaching

	-- Handle by curve type + speed tier
	if IsNoCurve() then
		-- Straight balls: parry earlier, especially at 600/750/900
		if speed >= 700 and speed < 850 then
			-- Straight + far + ~759 speed was too late: parry earlier
			threshold = 0.32
			approaching = dot > 0.45
		elseif hyperFast then
			-- Straight ball speed 850+ at mid range was too late: parry even earlier
			threshold = 0.40
			approaching = dot > 0.35
		elseif ultraFast then
			threshold = 0.22
			approaching = dot > 0.58
		else
			threshold = math.clamp(0.17 + (speed/1000), 0.14, 0.24)
			approaching = dot > 0.58
		end
	elseif IsLightCurve() then
		-- Slight curve: for ~600-700 speed, parry earlier (was too late)
		if speed >= 650 and speed < 850 then
			threshold = 0.21
			approaching = dot > 0.90
		elseif ultraFast and not hyperFast and distance > 7 and math.abs(dot) < 0.90 then
			return
		else
			threshold = hyperFast and 0.24 or 0.16
			approaching = hyperFast and (dot > 0.88) or (dot > 0.97)
		end
	else
		-- Strong curve: wait until committed
		local behindEnemyCurve = (dot < 0.35 and distance > 10 and speed > 75)
		if behindEnemyCurve then return end
		if hyperFast and distance > 10 and dot < 0.75 then return end
		if distance > 8 then return end
		threshold = hyperFast and 0.22 or 0.14
		approaching = hyperFast and (dot > 0.90) or (dot > 0.98)
	end

	local closeRange = distance < 6
	if approaching and (timeToHit <= threshold or closeRange) and tick()-LastParry > Cooldown then
		Parry()
	end
end)
